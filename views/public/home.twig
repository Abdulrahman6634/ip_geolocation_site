    <script>
        // Theme toggle functionality
        const themeToggle = document.getElementById('theme-toggle');
        themeToggle.addEventListener('click', () => {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
        });

        // Mobile menu toggle
        const mobileMenuButton = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        
        mobileMenuButton.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
        });

        // Function to toggle views
        function toggleView(view) {
            // Hide all tab content
            document.getElementById('cardView').style.display = 'none';
            document.getElementById('jsonView').style.display = 'none';
            
            // Show the selected tab content
            document.getElementById(view + 'View').style.display = 'block';
            
            // Update button styles
            if (view === 'card') {
                document.getElementById('cardViewBtn').classList.add('text-white', 'bg-primary-500', 'dark:bg-primary-600');
                document.getElementById('cardViewBtn').classList.remove('text-secondary-900', 'bg-white', 'dark:bg-secondary-700');
                document.getElementById('jsonViewBtn').classList.add('text-secondary-900', 'bg-white', 'dark:bg-secondary-700');
                document.getElementById('jsonViewBtn').classList.remove('text-white', 'bg-primary-500', 'dark:bg-primary-600');
            } else {
                document.getElementById('jsonViewBtn').classList.add('text-white', 'bg-primary-500', 'dark:bg-primary-600');
                document.getElementById('jsonViewBtn').classList.remove('text-secondary-900', 'bg-white', 'dark:bg-secondary-700');
                document.getElementById('cardViewBtn').classList.add('text-secondary-900', 'bg-white', 'dark:bg-secondary-700');
                document.getElementById('cardViewBtn').classList.remove('text-white', 'bg-primary-500', 'dark:bg-primary-600');
            }
        }

        // Copy JSON functionality
        document.getElementById('copyJsonBtn').addEventListener('click', function() {
            const jsonText = document.getElementById('jsonData').textContent;
            navigator.clipboard.writeText(jsonText).then(() => {
                // Change button text temporarily
                const originalHtml = this.innerHTML;
                this.innerHTML = '<i class="fa-solid fa-check mr-1"></i> Copied!';
                setTimeout(() => {
                    this.innerHTML = originalHtml;
                }, 2000);
            });
        });

        // Smooth scroll to sections
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const targetId = this.getAttribute('href').substring(1);
                if (targetId) {
                    document.getElementById(targetId).scrollIntoView({
                        behavior: 'smooth'
                    });
                }
            });
        });

        // IP form submission
        document.getElementById('ipForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const ip = document.getElementById('ipInput').value.trim();
            
            // Show loading indicator
            document.getElementById('loadingIndicator').classList.remove('hidden');
            document.getElementById('resultsContainer').classList.add('hidden');
            
            try {
                // Determine the API URL: if IP is empty, fetch own IP; otherwise, fetch specified IP
                const apiUrl = ip ? `https://ipwho.is/${ip}` : 'https://ipwho.is/';
                
                const response = await fetch(apiUrl);
                if (!response.ok) {
                    throw new Error('API request failed');
                }
                
                const data = await response.json();
                if (!data.success) {
                    throw new Error(data.message || 'Invalid IP or API error');
                }
                
                // Extract and format the data
                const geoData = {
                    ip: data.ip,
                    ipv: (data.ip.includes(':')) ? 'IPv6' : 'IPv4',
                    latitude: data.latitude,
                    longitude: data.longitude,
                    country: data.country,
                    country_code: data.country_code,
                    city: data.city,
                    population: data.population || '',  // Not always available
                    region: data.region,
                    continent: data.continent,
                    continent_code: data.continent_code,
                    postal: data.postal,
                    asn: data.connection ? `AS${data.connection.asn}` : 'Unknown',
                    isp: data.connection ? data.connection.isp : 'Unknown',
                    proxy: data.connection ? (data.connection.proxy ? 'Yes' : 'No') : 'Unknown',
                    type: data.type || 'Unknown',
                };
                const country = {
                    language: data.languages ? Object.values(data.languages)[0].name : 'Unknown',
                    currency: data.currency ? `${data.currency.code} (${data.currency.symbol})` : 'Unknown'
                };

                
                // Update card view
                document.getElementById('result-ip').textContent = geoData.ip;
                document.getElementById('result-version').textContent = geoData.ipv;
                document.getElementById('result-coordinates').textContent = `${geoData.latitude}, ${geoData.longitude}`;
                document.getElementById('result-coordinates').href = `https://www.google.com/maps?q=${geoData.latitude},${geoData.longitude}`;
                document.getElementById('result-country').textContent = geoData.country;
                document.getElementById('result-country-code').textContent = geoData.country_code;
                document.getElementById('result-region-city').textContent = `${geoData.region}, ${geoData.city}`;
                document.getElementById('result-population').textContent = geoData.population ? `Population: ${geoData.population}` : '';
                document.getElementById('result-continent').textContent = geoData.continent;
                document.getElementById('result-continent-code').textContent = geoData.continent_code;
                document.getElementById('result-postal').textContent = geoData.postal;
                document.getElementById('result-currency').textContent = country.currency;
                document.getElementById('result-language').textContent = country.language;
                document.getElementById('result-asn').textContent = geoData.asn;
                document.getElementById('result-isp').textContent = geoData.isp;
                document.getElementById('result-proxy').innerHTML = `<i class="fa-solid fa-shield-alt mr-1"></i> Proxy: ${geoData.proxy}`;
                document.getElementById('result-type').innerHTML = `<i class="fa-solid fa-network-wired mr-1"></i> Type: ${geoData.type}`;
                
                // Update JSON view with the full API response
                document.getElementById('jsonData').textContent = JSON.stringify(data, null, 2);
                
                // Hide loading and show results
                document.getElementById('loadingIndicator').classList.add('hidden');
                document.getElementById('resultsContainer').classList.remove('hidden');
                
                // Set default to card view
                toggleView('card');
            } catch (error) {
                // Hide loading and show error
                document.getElementById('loadingIndicator').classList.add('hidden');
                alert(`Error: ${error.message}. Please try a valid IP address.`);
            }
        });

        // Add event listeners to buttons
        document.getElementById('cardViewBtn').addEventListener('click', () => toggleView('card'));
        document.getElementById('jsonViewBtn').addEventListener('click', () => toggleView('json'));

        // Check for saved theme preference
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
    </script>
