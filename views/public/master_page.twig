    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>

    <script>
        // Set initial active page based on URL
        function setInitialActivePage() {
            const path = window.location.pathname;
            const links = document.querySelectorAll('.nav-link');
            const mobileLinks = document.querySelectorAll('.nav-link-mobile');
            
            // Update desktop navigation
            links.forEach(link => {
                link.classList.remove('text-primary-600', 'active');
                link.classList.add('text-gray-900', 'dark:text-white');
                
                if (link.getAttribute('href') === path) {
                    link.classList.add('text-primary-600', 'active');
                    link.classList.remove('text-gray-900', 'dark:text-white');
                }
            });
            
            // Update mobile navigation
            mobileLinks.forEach(link => {
                link.classList.remove('active');
                
                if (link.getAttribute('href') === path) {
                    link.classList.add('active');
                }
            });
        }
        
        // Theme toggle functionality
        function setupThemeToggle(toggleButton, toggleHandler) {
            toggleButton.addEventListener('click', function() {
                const html = document.documentElement;
                
                if (html.classList.contains('dark')) {
                    html.classList.remove('dark');
                    toggleHandler.style.transform = 'translateX(0)';
                    localStorage.setItem('theme', 'light');
                } else {
                    html.classList.add('dark');
                    toggleHandler.style.transform = 'translateX(1.25rem)';
                    localStorage.setItem('theme', 'dark');
                }
            });
        }
        
        // Check for saved theme preference
        function applySavedTheme() {
            if (localStorage.getItem('theme') === 'dark') {
                document.documentElement.classList.add('dark');
                document.getElementById('theme-toggle-handler').style.transform = 'translateX(1.25rem)';
                document.getElementById('mobile-theme-toggle-handler').style.transform = 'translateX(1.25rem)';
            } else {
                document.documentElement.classList.remove('dark');
                document.getElementById('theme-toggle-handler').style.transform = 'translateX(0)';
                document.getElementById('mobile-theme-toggle-handler').style.transform = 'translateX(0)';
            }
        }
        
        // Avatar dropdown functionality
        document.getElementById('avatar-button').addEventListener('click', function(e) {
            e.stopPropagation();
            const avatarMenu = document.getElementById('avatar-menu');
            avatarMenu.classList.toggle('hidden');
        });
        
        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const avatarButton = document.getElementById('avatar-button');
            const avatarMenu = document.getElementById('avatar-menu');
            
            if (!avatarButton.contains(event.target) && !avatarMenu.contains(event.target) && !avatarMenu.classList.contains('hidden')) {
                avatarMenu.classList.add('hidden');
            }
        });
        
        // Mobile menu toggle (sidebar)
        document.getElementById('menu-toggle').addEventListener('click', function() {
            document.getElementById('mobile-sidebar').classList.remove('hidden');
            document.getElementById('sidebar-backdrop').classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        });
        
        // Close sidebar
        document.getElementById('close-sidebar').addEventListener('click', function() {
            document.getElementById('mobile-sidebar').classList.add('hidden');
            document.getElementById('sidebar-backdrop').classList.add('hidden');
            document.body.style.overflow = 'auto';
        });
        
        // Close sidebar when clicking on backdrop
        document.getElementById('sidebar-backdrop').addEventListener('click', function() {
            document.getElementById('mobile-sidebar').classList.add('hidden');
            document.getElementById('sidebar-backdrop').classList.add('hidden');
            document.body.style.overflow = 'auto';
        });
        
        // Setup theme toggles
        setupThemeToggle(document.getElementById('theme-toggle'), document.getElementById('theme-toggle-handler'));
        setupThemeToggle(document.getElementById('mobile-theme-toggle'), document.getElementById('mobile-theme-toggle-handler'));
        
        // Initialize active page on load
        setInitialActivePage();
        
        // Apply saved theme on load
        applySavedTheme();
    </script>

    {% block script %}
    {% endblock %}

</body>
