{% extends '/public/master_page.twig' %}

{% block content %}

<!-- Header Section -->
<div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">API Usage Statistics</h1>
    <p class="text-gray-600 dark:text-gray-400">Monitor your IP Geolocation API usage and track your consumption patterns</p>
</div>

<!-- Date Range Selector -->
<div class="card p-4 mb-6">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-2 md:mb-0">Usage Overview</h2>
        <div class="flex items-center space-x-2">
            <select id="date-range" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500">
                <option value="7">Last 7 days</option>
                <option value="30" selected>Last 30 days</option>
                <option value="90">Last 90 days</option>
                <option value="365">Last year</option>
            </select>
            <button class="btn-primary text-white px-3 py-2.5 text-sm font-medium rounded-lg focus:ring-4 focus:ring-primary-300 focus:outline-none">
                <i class="fa-solid fa-download mr-1"></i> Export
            </button>
        </div>
    </div>
</div>

<!-- Usage Summary Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="card p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-primary-100 dark:bg-primary-900 mr-4">
                <i class="fa-solid fa-chart-line text-primary-600 dark:text-primary-300 text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">Total Requests</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">{{ stats.total }}</h3>
            </div>
        </div>
    </div>

    <div class="card p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-green-100 dark:bg-green-900 mr-4">
                <i class="fa-solid fa-check-circle text-green-600 dark:text-green-300 text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">Successful Requests</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">{{ stats.success }}</h3>
            </div>
        </div>
    </div>

    <div class="card p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-red-100 dark:bg-red-900 mr-4">
                <i class="fa-solid fa-triangle-exclamation text-red-600 dark:text-red-300 text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">Failed Requests</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">{{ stats.failed }}</h3>
            </div>
        </div>
    </div>

    <div class="card p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-primary-100 dark:bg-primary-900 mr-4">
                <i class="fa-solid fa-gauge-high text-primary-600 dark:text-primary-300 text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-600 dark:text-gray-400">Average Response Time</p>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white">{{ stats.avgTime }} ms</h3>
            </div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="card p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Requests Over Time</h2>
        <div class="h-80">
            <canvas id="requestsChart"></canvas>
        </div>
    </div>

    <div class="card p-6">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Usage by Response Status</h2>
        <div class="h-80">
            <canvas id="responseStatusChart"></canvas>
        </div>
    </div>
</div>

<!-- Recent API Activity Section -->
<div class="card p-6 mb-8">
    <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4">Recent API Activity</h2>

    <!-- Search & Rows -->
    <div class="flex items-center justify-between mb-4">
        <div>
            <label for="rowsPerPage" class="mr-2 text-sm text-gray-700 dark:text-gray-300">Show</label>
            <select id="rowsPerPage" class="border rounded p-1 text-sm dark:bg-gray-800 dark:text-white">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <span class="ml-1 text-sm text-gray-700 dark:text-gray-300">entries</span>
        </div>
        <div>
            <input type="text" id="searchInput" placeholder="Search..." 
                   class="border rounded p-1 text-sm dark:bg-gray-800 dark:text-white">
        </div>
    </div>

    <!-- Table -->
    <div class="relative overflow-x-auto shadow-md sm:rounded-lg">
        <table id="activityTable" class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                <tr>
                    <th class="px-4 py-3">Timestamp</th>
                    <th class="px-4 py-3">API Key</th>
                    <th class="px-4 py-3">Endpoint</th>
                    <th class="px-4 py-3">IP Address</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Response Time (ms)</th>
                    <th class="px-4 py-3">User Agent</th>
                </tr>
            </thead>
            <tbody id="activityTableBody">
                {% for row in activity %}
                    <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700">
                        <td class="px-4 py-3">{{ row.timestamp }}</td>
                        <td class="px-4 py-3">{{ row.api_key }}</td>
                        <td class="px-4 py-3">{{ row.endpoint }}</td>
                        <td class="px-4 py-3">{{ row.ip_address }}</td>
                        <td class="px-4 py-3">
                            {% if row.status_code == 200 %}
                                <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300">Success</span>
                            {% else %}
                                <span class="bg-red-100 text-red-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-red-900 dark:text-red-300">Failed</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-3">{{ row.response_time_ms }}ms</td>
                        <td class="px-4 py-3">{{ row.user_agent }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between mt-4">
        <p id="tableInfo" class="text-sm text-gray-600 dark:text-gray-300"></p>
        <div class="flex space-x-2">
            <button id="prevPage" class="px-3 py-1 text-sm bg-gray-200 rounded dark:bg-gray-700 dark:text-white">Prev</button>
            <button id="nextPage" class="px-3 py-1 text-sm bg-gray-200 rounded dark:bg-gray-700 dark:text-white">Next</button>
        </div>
    </div>
</div>

{% endblock %}

{% block script %}
<script>
document.addEventListener('DOMContentLoaded', function() {

    // Fake chart demo – replace with PHP injected data if needed
    const requestsCtx = document.getElementById('requestsChart').getContext('2d');
    new Chart(requestsCtx, {
        type: 'line',
        data: {
            labels: ['Day 1','Day 2','Day 3','Day 4','Day 5'],
            datasets: [
                { label: 'Total Requests', data: [50,70,60,90,85], borderColor:'rgb(59,130,246)', backgroundColor:'rgba(59,130,246,0.1)', fill:true },
                { label: 'Success', data: [48,68,58,88,83], borderColor:'rgb(34,197,94)', backgroundColor:'rgba(34,197,94,0.1)', fill:true },
                { label: 'Failed', data: [2,2,2,2,2], borderColor:'rgb(239,68,68)', backgroundColor:'rgba(239,68,68,0.1)', fill:true }
            ]
        },
        options: { responsive:true, maintainAspectRatio:false }
    });

    const responseCtx = document.getElementById('responseStatusChart').getContext('2d');
    new Chart(responseCtx, {
        type: 'doughnut',
        data: {
            labels: ['Success','Failed'],
            datasets: [{ data: [{{ stats.success }}, {{ stats.failed }}],
                backgroundColor: ['rgb(34,197,94)','rgb(239,68,68)'] }]
        },
        options: { responsive:true, maintainAspectRatio:false }
    });

    // Table Search + Pagination
    const rowsPerPageSelect = document.getElementById("rowsPerPage");
    const searchInput = document.getElementById("searchInput");
    const tableBody = document.getElementById("activityTableBody");
    const allRows = Array.from(tableBody.getElementsByTagName("tr"));
    const prevPageBtn = document.getElementById("prevPage");
    const nextPageBtn = document.getElementById("nextPage");
    const tableInfo = document.getElementById("tableInfo");

    let currentPage = 1;
    let rowsPerPage = parseInt(rowsPerPageSelect.value);

    function renderTable() {
        const searchTerm = searchInput.value.toLowerCase();
        const filteredRows = allRows.filter(row => row.textContent.toLowerCase().includes(searchTerm));
        const totalPages = Math.ceil(filteredRows.length / rowsPerPage);
        currentPage = Math.min(currentPage, totalPages) || 1;

        tableBody.innerHTML = "";
        const start = (currentPage - 1) * rowsPerPage;
        const end = start + rowsPerPage;
        filteredRows.slice(start, end).forEach(row => tableBody.appendChild(row));

        tableInfo.textContent = `Showing ${start+1} to ${Math.min(end, filteredRows.length)} of ${filteredRows.length} entries`;
        prevPageBtn.disabled = currentPage === 1;
        nextPageBtn.disabled = currentPage === totalPages || totalPages === 0;
    }

    rowsPerPageSelect.addEventListener("change", () => { rowsPerPage = parseInt(rowsPerPageSelect.value); currentPage = 1; renderTable(); });
    searchInput.addEventListener("input", () => { currentPage = 1; renderTable(); });
    prevPageBtn.addEventListener("click", () => { if (currentPage > 1) { currentPage--; renderTable(); } });
    nextPageBtn.addEventListener("click", () => { currentPage++; renderTable(); });

    renderTable();
});
</script>
{% endblock %}
