{% extends '/public/master_page.twig' %}

{% block content %}
    <!-- API Key Management Section -->
    <div class="card p-6 mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">API Key Management</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-6">
            Your API key is required to authenticate all requests to the IP Geolocation API. Keep it secure and never expose it in client-side code.
        </p>
        
        <!-- API Key Details -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div class="bg-primary-50 dark:bg-gray-700 p-4 rounded-lg">
                <div class="flex items-center mb-2">
                    <div class="p-2 rounded-full bg-primary-100 dark:bg-primary-900 mr-3">
                        <i class="fa-solid fa-key text-primary-600 dark:text-primary-300"></i>
                    </div>
                    <h3 class="font-semibold text-gray-900 dark:text-white">Usage Limits</h3>
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                    Your current plan allows for <span class="font-medium">1,000 requests per day</span>. Upgrade your plan for higher limits.
                </p>
            </div>
            
            <div class="bg-primary-50 dark:bg-gray-700 p-4 rounded-lg">
                <div class="flex items-center mb-2">
                    <div class="p-2 rounded-full bg-primary-100 dark:bg-primary-900 mr-3">
                        <i class="fa-solid fa-shield text-primary-600 dark:text-primary-300"></i>
                    </div>
                    <h3 class="font-semibold text-gray-900 dark:text-white">Security</h3>
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                    Include your API key in the <code class="bg-gray-200 dark:bg-gray-600 px-1 rounded">X-API-Key</code> header of all requests to our API endpoints.
                </p>
            </div>
        </div>
        
        <!-- API Key Display -->
        <div class="mb-6">
            <label for="apiKey" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Your API Key</label>
            <div class="flex">
                <input type="password" id="apiKey" value="{{ key.token }}" class="rounded-l-lg bg-gray-50 border border-gray-300 text-gray-900 focus:ring-primary-500 focus:border-primary-500 block flex-1 w-full p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500" readonly>
                <button id="toggleKeyVisibility" class="inline-flex items-center px-3 text-sm text-gray-900 bg-gray-200 border border-gray-300 border-l-0 rounded-r-md dark:bg-gray-600 dark:text-white dark:border-gray-600">
                    <i class="fa-solid fa-eye"></i>
                </button>
                <button id="copyApiKey" class="ml-2 inline-flex items-center px-4 py-2 text-sm font-medium text-gray-900 bg-white border border-gray-300 rounded-lg hover:bg-gray-100 focus:ring-2 focus:ring-primary-500 dark:bg-gray-700 dark:text-white dark:border-gray-600 dark:hover:bg-gray-600">
                    <i class="fa-regular fa-copy mr-2"></i> Copy
                </button>
            </div>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Treat this key like a password. If compromised, regenerate it immediately.</p>
        </div>
        
        <!-- Generate New Key Button -->
        <button id="generateNewKey" type="submit" class="btn-primary text-white font-medium rounded-lg text-sm px-5 py-2.5">
            <i class="fa-solid fa-key mr-2"></i> Generate New API Key
        </button>
        
        <!-- Confirmation Modal (hidden by default) -->
        <div id="regenerateModal" class="hidden fixed inset-0 bg-gray-600 bg-opacity-50 flex items-center justify-center z-30">
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl p-6 m-4 max-w-md w-full">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Generate New API Key</h3>
                <p class="text-gray-600 dark:text-gray-400 mb-6">This will invalidate your current API key. Any applications using the current key will stop working. Are you sure you want to continue?</p>
                <div class="flex justify-end space-x-4">
                    <button id="cancelRegenerate" class="px-4 py-2 text-gray-700 bg-gray-200 rounded-lg hover:bg-gray-300 dark:text-gray-300 dark:bg-gray-700 dark:hover:bg-gray-600">Cancel</button>
                    <button id="confirmRegenerate" class="px-4 py-2 text-white bg-red-600 rounded-lg hover:bg-red-700 dark:bg-red-500 dark:hover:bg-red-600">Generate New Key</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Usage Statistics -->
    <div class="card p-6">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">API Usage</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-primary-50 dark:bg-gray-700 p-4 rounded-lg">
                <p class="text-sm text-gray-600 dark:text-gray-300">Today's Requests</p>
                <p class="text-2xl font-bold text-primary-600 dark:text-primary-400">247/1,000</p>
            </div>
            <div class="bg-primary-50 dark:bg-gray-700 p-4 rounded-lg">
                <p class="text-sm text-gray-600 dark:text-gray-300">This Month's Requests</p>
                <p class="text-2xl font-bold text-primary-600 dark:text-primary-400">12,458/30,000</p>
            </div>
            <div class="bg-primary-50 dark:bg-gray-700 p-4 rounded-lg">
                <p class="text-sm text-gray-600 dark:text-gray-300">Total Requests</p>
                <p class="text-2xl font-bold text-primary-600 dark:text-primary-400">184,729</p>
            </div>
        </div>
    </div>
{% endblock %}

{% block script %}
<script>
    // API Key Visibility Toggle
    document.getElementById('toggleKeyVisibility').addEventListener('click', function() {
        const apiKeyInput = document.getElementById('apiKey');
        const icon = this.querySelector('i');
        
        if (apiKeyInput.type === 'password') {
            apiKeyInput.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            apiKeyInput.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    });

    // Copy API Key
    document.getElementById('copyApiKey').addEventListener('click', function() {
        const apiKeyInput = document.getElementById('apiKey');
        apiKeyInput.select();
        document.execCommand('copy');
        
        // Show feedback
        const originalText = this.innerHTML;
        this.innerHTML = '<i class="fa-solid fa-check mr-2"></i> Copied!';
        setTimeout(() => {
            this.innerHTML = originalText;
        }, 2000);
    });

    // Modal functionality
    document.getElementById('generateNewKey').addEventListener('click', function() {
        document.getElementById('regenerateModal').classList.remove('hidden');
    });

    document.getElementById('cancelRegenerate').addEventListener('click', function() {
        document.getElementById('regenerateModal').classList.add('hidden');
    });

    document.getElementById('confirmRegenerate').addEventListener('click', function() {
        // AJAX call to regenerate key
        $.ajax({
            url: '/api_key',
            type: 'POST',
            success: function(response) {
                try {
                    const res = JSON.parse(response);
                    if (res.statusCode === 200 && res.token) {
                        // Update the key value
                        document.getElementById('apiKey').value = res.token;
                        // Hide modal
                        document.getElementById('regenerateModal').classList.add('hidden');
                    } else {
                        console.error('Failed to generate key:', res.message);
                        alert(res.message || 'Failed to generate API key.');
                    }
                } catch (error) {
                    console.error('Invalid JSON response:', response);
                    alert('Server returned invalid response.');
                }
            },
            error: function(xhr, status, error) {
                console.error('AJAX Error:', status, error);
                alert('Error while generating new key.');
            }
        });
    });
</script>
{% endblock %}