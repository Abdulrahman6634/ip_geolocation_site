{% extends '/public/master_page.twig' %}

{% block content %}

        <!-- Header Section -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Choose Your Plan</h1>
            <p class="text-gray-600 dark:text-gray-400 max-w-2xl">Select the subscription that best fits your IP geolocation API needs. All plans include full API access with different request limits.</p>
        </div>

        <!-- Pricing Plans -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <!-- Free Plan -->
            <div class="card p-6">
                <h3 class="mb-4 text-2xl font-semibold text-gray-900 dark:text-white">Free</h3>
                <p class="font-light text-gray-600 dark:text-gray-400 mb-4">Ideal for testing and development</p>
                <div class="flex justify-center items-baseline my-6">
                    <span class="mr-2 text-5xl font-extrabold text-gray-900 dark:text-white">$0</span>
                    <span class="text-gray-600 dark:text-gray-400">/month</span>
                </div>
                <ul role="list" class="mb-6 space-y-4 text-left">
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">1,000 requests per day</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Basic location data</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">1 API key</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-xmark text-red-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">No technical support</span>
                    </li>
                </ul>
                <a href="/payment_processing" class="text-white bg-gray-600 hover:bg-gray-700 focus:ring-4 focus:ring-gray-200 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-gray-600 dark:hover:bg-gray-700 block">Current Plan</a>
            </div>
            
            <!-- Professional Plan -->
            <div class="card p-6 relative border border-primary-600 dark:border-primary-500 transform scale-105">
                <div class="absolute top-0 right-0 m-4">
                    <span class="bg-primary-100 text-primary-800 text-xs font-semibold px-2.5 py-0.5 rounded dark:bg-primary-200 dark:text-primary-800">Popular</span>
                </div>
                <h3 class="mb-4 text-2xl font-semibold text-gray-900 dark:text-white">Professional</h3>
                <p class="font-light text-gray-600 dark:text-gray-400 mb-4">For growing businesses and applications</p>
                <div class="flex justify-center items-baseline my-6">
                    <span class="mr-2 text-5xl font-extrabold text-gray-900 dark:text-white">$29</span>
                    <span class="text-gray-600 dark:text-gray-400">/month</span>
                </div>
                <ul role="list" class="mb-6 space-y-4 text-left">
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">10,000 requests per day</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Advanced location data</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">5 API keys</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Email support</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Basic analytics</span>
                    </li>
                </ul>
                <a href="/payment_processing" class="btn-primary text-white font-medium rounded-lg text-sm px-5 py-2.5 text-center block">Upgrade Now</a>
            </div>
            
            <!-- Enterprise Plan -->
            <div class="card p-6">
                <h3 class="mb-4 text-2xl font-semibold text-gray-900 dark:text-white">Enterprise</h3>
                <p class="font-light text-gray-600 dark:text-gray-400 mb-4">For large-scale applications</p>
                <div class="flex justify-center items-baseline my-6">
                    <span class="mr-2 text-5xl font-extrabold text-gray-900 dark:text-white">$99</span>
                    <span class="text-gray-600 dark:text-gray-400">/month</span>
                </div>
                <ul role="list" class="mb-6 space-y-4 text-left">
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Unlimited requests</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Full location data with ISP details</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Unlimited API keys</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Priority 24/7 support</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Advanced analytics dashboard</span>
                    </li>
                    <li class="flex items-center space-x-3">
                        <i class="fa-solid fa-check text-green-500"></i>
                        <span class="text-gray-600 dark:text-gray-300">Custom data fields available</span>
                    </li>
                </ul>
                <a href="/payment_processing" class="btn-primary text-white font-medium rounded-lg text-sm px-5 py-2.5 text-center block">Upgrade Now</a>
            </div>
        </div>

        <!-- FAQ Section -->
        <div class="card p-6 mb-8">
            <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6 text-center">Frequently Asked Questions</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">How does billing work?</h3>
                    <p class="text-gray-600 dark:text-gray-400">We offer monthly billing. Payments are processed securely through our payment partners.</p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Can I change plans anytime?</h3>
                    <p class="text-gray-600 dark:text-gray-400">Yes, you can upgrade your plan at any time. Downgrades will take effect at the end of your current billing cycle.</p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">What payment methods do you accept?</h3>
                    <p class="text-gray-600 dark:text-gray-400">We accept all major credit cards, PayPal, and bank transfers for enterprise customers.</p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Is there a free trial?</h3>
                    <p class="text-gray-600 dark:text-gray-400">All paid plans come with a 14-day free trial. No credit card required to start a trial.</p>
                </div>
            </div>
        </div>

{% endblock %}

{% block script %}

    <script>
        // Plan selection functionality
        document.querySelectorAll('a').forEach(link => {
            if (link.textContent === 'Upgrade Now') {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    const plan = this.closest('.card').querySelector('h3').textContent;
                    alert(`You've selected the ${plan} plan. In a real application, this would redirect to a payment processing page.`);
                });
            }
        });
    </script>

{% endblock %}